<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StellarLauncher.App.ViewModels"
        xmlns:views="using:StellarLauncher.App.Views"
        x:Class="StellarLauncher.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="880" Height="560" Title="Stellar Launcher"
        Icon="/Assets/stellar-window.png"
        Background="#080a12">
  <Window.Styles>
    <Style Selector="Path.glow">
      <Style.Animations>
        <Animation Duration="0:0:1.8" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.30"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.95"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Uniform nav buttons: identical box + a 24×24 vector icon so all three render the same size
         (the old emoji/symbol glyphs scaled inconsistently). -->
    <Style Selector="Button.nav">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Width" Value="44"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.nav > Viewbox"><Setter Property="Width" Value="22"/><Setter Property="Height" Value="22"/></Style>
  </Window.Styles>
  <Grid ColumnDefinitions="74,*">
    <StackPanel Grid.Column="0" Background="#0a0d18" Spacing="14"
                HorizontalAlignment="Stretch">
      <!-- Stellar mark: glowing cyan 4-point sparkle (animated pulse), matching the in-game logo -->
      <Panel Width="48" Height="48" Margin="0,18,0,18" HorizontalAlignment="Center">
        <Viewbox Width="48" Height="48">
          <Path Classes="glow" Fill="#46d6ff"
                Data="M12,1 L13.9,10.1 L23,12 L13.9,13.9 L12,23 L10.1,13.9 L1,12 L10.1,10.1 Z">
            <Path.Effect><BlurEffect Radius="7"/></Path.Effect>
          </Path>
        </Viewbox>
        <Viewbox Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Path Fill="#d6f3ff"
                Data="M12,1 L13.9,10.1 L23,12 L13.9,13.9 L12,23 L10.1,13.9 L1,12 L10.1,10.1 Z"/>
        </Viewbox>
      </Panel>
      <Button Classes="nav" Command="{Binding ShowHomeCommand}" ToolTip.Tip="Home">
        <Viewbox><Canvas Width="24" Height="24">
          <Path Fill="#cfd6f0" Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"/>
        </Canvas></Viewbox>
      </Button>
      <Button Classes="nav" Command="{Binding ShowPluginsCommand}" ToolTip.Tip="Plugins">
        <Viewbox><Canvas Width="24" Height="24">
          <Path Fill="#cfd6f0" Data="M20.5,11H19V7C19,5.89 18.1,5 17,5H13V3.5A2.5,2.5 0 0,0 10.5,1A2.5,2.5 0 0,0 8,3.5V5H4A2,2 0 0,0 2,7V10.8H3.5C5,10.8 6.2,12 6.2,13.5C6.2,15 5,16.2 3.5,16.2H2V20A2,2 0 0,0 4,22H7.8V20.5C7.8,19 9,17.8 10.5,17.8C12,17.8 13.2,19 13.2,20.5V22H17A2,2 0 0,0 19,20V16H20.5A2.5,2.5 0 0,0 23,13.5A2.5,2.5 0 0,0 20.5,11Z"/>
        </Canvas></Viewbox>
      </Button>
      <Button Classes="nav" Command="{Binding ShowSettingsCommand}" ToolTip.Tip="Settings">
        <Viewbox><Canvas Width="24" Height="24">
          <Path Fill="#cfd6f0" Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
        </Canvas></Viewbox>
      </Button>
    </StackPanel>

    <ContentControl Grid.Column="1" Content="{Binding Current}">
      <ContentControl.DataTemplates>
        <DataTemplate DataType="vm:HomeViewModel"><views:HomeView/></DataTemplate>
        <DataTemplate DataType="vm:PluginsViewModel"><views:PluginsView/></DataTemplate>
        <DataTemplate DataType="vm:SettingsViewModel"><views:SettingsView/></DataTemplate>
      </ContentControl.DataTemplates>
    </ContentControl>
  </Grid>
</Window>
