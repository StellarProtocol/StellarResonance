<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StellarLauncher.App.ViewModels"
             x:Class="StellarLauncher.App.Views.PluginsView"
             x:DataType="vm:PluginsViewModel">
  <Grid RowDefinitions="Auto,Auto,*">
    <StackPanel Grid.Row="0" Margin="28,24,28,8" Spacing="3">
      <TextBlock Text="Plugins" Foreground="White" FontSize="20" FontWeight="Bold"/>
      <TextBlock Text="{Binding Status}" Foreground="#8a93b2" FontSize="12"/>
    </StackPanel>

    <!-- add 3rd-party repo + existing repos -->
    <StackPanel Grid.Row="1" Margin="28,0,28,10" Spacing="6">
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0" Text="{Binding NewRepoUrl}"
                 PlaceholderText="add a 3rd-party plugin repo URL (a plugins.json)"/>
        <Button Grid.Column="1" Content="Add repo" Command="{Binding AddRepoCommand}" Margin="8,0,0,0"/>
      </Grid>
      <ItemsControl ItemsSource="{Binding Repos}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="x:String">
            <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
              <TextBlock Grid.Column="0" Text="{Binding}" Foreground="#8a93b2" FontSize="11" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Content="✕" FontSize="11" Padding="8,2"
                      Background="Transparent" Foreground="#9aa3bf"
                      Command="{Binding $parent[UserControl].((vm:PluginsViewModel)DataContext).RemoveRepoCommand}"
                      CommandParameter="{Binding}"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <!-- plugin list -->
    <ScrollViewer Grid.Row="2" Margin="28,0,28,16">
      <ItemsControl ItemsSource="{Binding Plugins}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:PluginItemViewModel">
            <Border Background="#141a2e" BorderBrush="#222a44" BorderThickness="1"
                    CornerRadius="12" Padding="15,13" Margin="0,0,0,10">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="3">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}" Foreground="#566083"
                               FontSize="11" VerticalAlignment="Center"/>
                    <Border Background="#2354e3a0" CornerRadius="5" Padding="6,1" IsVisible="{Binding Installed}">
                      <TextBlock Text="INSTALLED" Foreground="#9affd0" FontSize="9" FontWeight="Bold"/>
                    </Border>
                  </StackPanel>
                  <TextBlock Text="{Binding Description}" Foreground="#c5cce0" FontSize="12" TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding Action}" Foreground="#7ee0a0" FontSize="11"
                             IsVisible="{Binding Action, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <Button Content="Install" Command="{Binding InstallCommand}" IsVisible="{Binding !Installed}"
                          Foreground="#0b0e16" Background="#54e3a0" FontWeight="Bold" Padding="16,6" CornerRadius="8"/>
                  <Button Content="Remove" Command="{Binding RemoveCommand}" IsVisible="{Binding Installed}"
                          Foreground="#cfd6f0" Background="#2a1c2f" BorderBrush="#5b2f45" BorderThickness="1"
                          Padding="14,6" CornerRadius="8"/>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
