<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StellarLauncher.App.ViewModels"
             xmlns:model="using:StellarLauncher.Core.Model"
             xmlns:sys="using:System"
             x:Class="StellarLauncher.App.Views.PluginsView"
             x:DataType="vm:PluginsViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*">
    <Grid.Styles>
      <Style Selector="Button.tab">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="#8a93b2"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
      </Style>
      <Style Selector="Button.tab:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="TextElement.Foreground" Value="#9aa3bf"/>
      </Style>
      <Style Selector="Button.tab.active">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
      </Style>
      <Style Selector="Button.tab.active:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="TextElement.Foreground" Value="White"/>
      </Style>
    </Grid.Styles>
    <StackPanel Grid.Row="0" Margin="28,24,28,8" Spacing="3">
      <TextBlock Text="Plugins" Foreground="White" FontSize="20" FontWeight="Bold"/>
      <TextBlock Text="{Binding Status}" Foreground="#8a93b2" FontSize="12"/>
    </StackPanel>

    <!-- add 3rd-party repo + existing repos -->
    <StackPanel Grid.Row="1" Margin="28,0,28,8" Spacing="6">
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0" Text="{Binding NewRepoUrl}"
                 PlaceholderText="add a 3rd-party plugin repo URL (a plugins.json)"/>
        <Button Grid.Column="1" Content="Add repo" Command="{Binding AddRepoCommand}" Margin="8,0,0,0"/>
      </Grid>
      <ItemsControl ItemsSource="{Binding Repos}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="x:String">
            <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
              <TextBlock Grid.Column="0" Text="{Binding}" Foreground="#8a93b2" FontSize="11" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Content="✕" FontSize="11" Padding="8,2"
                      Background="Transparent" Foreground="#9aa3bf"
                      Command="{Binding $parent[UserControl].((vm:PluginsViewModel)DataContext).RemoveRepoCommand}"
                      CommandParameter="{Binding}"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <!-- tab bar -->
    <Border Grid.Row="2" BorderBrush="#1e2540" BorderThickness="0,0,0,1" Margin="28,0,28,0">
      <StackPanel Orientation="Horizontal" Spacing="0">
        <StackPanel>
          <Button Content="Available" Classes="tab" Classes.active="{Binding IsTabAvailable}"
                  Command="{Binding SetTabAvailableCommand}"/>
          <Border Height="2" Background="#54e3a0" IsVisible="{Binding IsTabAvailable}"/>
        </StackPanel>
        <StackPanel>
          <Button Content="{Binding InstalledTabLabel}" Classes="tab" Classes.active="{Binding IsTabInstalled}"
                  Command="{Binding SetTabInstalledCommand}"/>
          <Border Height="2" Background="#54e3a0" IsVisible="{Binding IsTabInstalled}"/>
        </StackPanel>
        <StackPanel>
          <Button Content="{Binding UpdatesTabLabel}" Classes="tab" Classes.active="{Binding IsTabUpdates}"
                  Command="{Binding SetTabUpdatesCommand}"/>
          <Border Height="2" Background="#54e3a0" IsVisible="{Binding IsTabUpdates}"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- plugin list -->
    <ScrollViewer Grid.Row="3" Margin="28,10,28,16">
      <ItemsControl ItemsSource="{Binding Plugins}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:PluginItemViewModel">
            <Border Background="#141a2e" BorderBrush="#222a44" BorderThickness="1"
                    CornerRadius="12" Padding="15,13" Margin="0,0,0,10">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                <StackPanel Grid.Column="0" Spacing="5">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Author}" Foreground="#566083" FontSize="11" VerticalAlignment="Center"/>
                    <Border Background="#2354e3a0" CornerRadius="5" Padding="6,1" IsVisible="{Binding Installed}">
                      <TextBlock Text="{Binding InstalledBadge}"
                                 Foreground="#9affd0" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Border Background="#40cc8800" CornerRadius="5" Padding="6,1" IsVisible="{Binding HasUpdate}"
                            BorderBrush="#ffb740" BorderThickness="1">
                      <TextBlock Text="UPDATE AVAILABLE" Foreground="#ffb740" FontSize="9" FontWeight="Bold"/>
                    </Border>
                  </StackPanel>
                  <TextBlock Text="{Binding Description}" Foreground="#c5cce0" FontSize="12" TextWrapping="Wrap"/>
                  <!-- selected version's changelog preview -->
                  <ItemsControl ItemsSource="{Binding SelectedChangelog.Added}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="sys:String">
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,1,0,0">
                          <Border Background="#2354e3a0" CornerRadius="5" Padding="6,1">
                            <TextBlock Text="ADDED" Foreground="#9affd0" FontSize="9" FontWeight="Bold"/>
                          </Border>
                          <TextBlock Text="{Binding}" Foreground="#aab3d0" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <ItemsControl ItemsSource="{Binding SelectedChangelog.Fixed}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="sys:String">
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,1,0,0">
                          <Border Background="#235b8cff" CornerRadius="5" Padding="6,1">
                            <TextBlock Text="FIXED" Foreground="#9ec2ff" FontSize="9" FontWeight="Bold"/>
                          </Border>
                          <TextBlock Text="{Binding}" Foreground="#aab3d0" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="{Binding CompatNote}" Foreground="#ff9a9a" FontSize="11"
                             IsVisible="{Binding CompatNote, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                  <TextBlock Text="{Binding Action}" Foreground="#7ee0a0" FontSize="11"
                             IsVisible="{Binding Action, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6" MinWidth="172">
                  <ComboBox HorizontalAlignment="Stretch"
                            ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="model:PluginVersion">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="{Binding Version, StringFormat='v{0}'}"/>
                          <TextBlock Text="{Binding Date}" Foreground="#697297"/>
                        </StackPanel>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <!-- action row -->
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6"
                              IsVisible="{Binding !ConfirmVisible}">
                    <!-- green = fresh install -->
                    <Button Content="{Binding InstallLabel}" Command="{Binding RequestInstallCommand}"
                            IsEnabled="{Binding Compatible}" IsVisible="{Binding IsPlainInstall}"
                            Foreground="#0b0e16" Background="#54e3a0" FontWeight="Bold" Padding="14,6" CornerRadius="8"/>
                    <!-- amber = update -->
                    <Button Content="{Binding InstallLabel}" Command="{Binding RequestInstallCommand}"
                            IsEnabled="{Binding Compatible}" IsVisible="{Binding IsUpdate}"
                            Foreground="#0b0e16" Background="#ffb740" FontWeight="Bold" Padding="14,6" CornerRadius="8"/>
                    <!-- muted = reinstall (already on this version) -->
                    <Button Content="{Binding InstallLabel}" Command="{Binding RequestInstallCommand}"
                            IsEnabled="{Binding Compatible}" IsVisible="{Binding IsReinstall}"
                            Foreground="#9aa3bf" Background="#1a2035" BorderBrush="#2f3a5a" BorderThickness="1"
                            Padding="14,6" CornerRadius="8"/>
                    <Button Content="Remove" Command="{Binding RemoveCommand}" IsVisible="{Binding Installed}"
                            Foreground="#cfd6f0" Background="#2a1c2f" BorderBrush="#5b2f45" BorderThickness="1"
                            Padding="12,6" CornerRadius="8"/>
                  </StackPanel>
                  <!-- inline confirm -->
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6"
                              IsVisible="{Binding ConfirmVisible}">
                    <TextBlock Text="⚠" Foreground="#ffcf6b" VerticalAlignment="Center" IsVisible="{Binding IsDowngrade}"/>
                    <Button Content="Cancel" Command="{Binding CancelInstallCommand}"
                            Foreground="#cfd6f0" Background="Transparent" BorderBrush="#2f4570" BorderThickness="1"
                            Padding="12,6" CornerRadius="8"/>
                    <Button Content="Confirm" Command="{Binding ConfirmInstallCommand}"
                            Foreground="#0b0e16" Background="#54e3a0" FontWeight="Bold" Padding="12,6" CornerRadius="8"/>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
