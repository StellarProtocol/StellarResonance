<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="StellarLauncher.App.App"
             RequestedThemeVariant="Dark">
             <!-- Pinned to Dark: the launcher's layout uses hardcoded dark backgrounds + light text,
                  so following the system variant ("Default") made buttons/toggles/checkboxes render
                  with Fluent's light-variant brushes (dark-on-dark, invisible) under a light OS theme. -->

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>